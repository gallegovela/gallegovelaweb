# Copia este fichero como .env.production y rellena los valores reales.
# .env.production NO se versiona (ver .gitignore).

# --- Conexión a la base de datos (obligatorio) ---
# Host de MySQL en producción. Incluye el puerto si no es el 3306 por defecto,
# por ejemplo: mysql.midominio.com:3306
WORDPRESS_DB_HOST=
WORDPRESS_DB_NAME=
WORDPRESS_DB_USER=
WORDPRESS_DB_PASSWORD=
WORDPRESS_TABLE_PREFIX=wp_

# --- Contenedor (opcional, tienen valores por defecto en el script) ---
# Nombre de la imagen y del contenedor Docker.
IMAGE_NAME=gallegovela-web
CONTAINER_NAME=gallegovela-web

# Puerto del host que se publica hacia el puerto 80 del contenedor.
HOST_PORT=80

# Carpeta del servidor donde persisten los uploads de WordPress
# (se monta en /var/www/html/wp-content/uploads para no perderlos al recrear el contenedor).
UPLOADS_HOST_PATH=/var/www/gallegovela.es/gallegovelaweb/uploads
